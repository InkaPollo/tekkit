-- Redirect to left monitor
local monitor = peripheral.wrap("left")
if not monitor then
    error("Left monitor not found!")
end
term.redirect(monitor)

-- Set text scale and display shell
monitor.setTextScale(1)
term.clear()
term.setCursorPos(1, 1)

-- Run shell on the left monitor
shell.run("shell")

-- Run home_screen after shell
shell.run("home_screen")
