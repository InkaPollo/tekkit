-- startup3.lua - Tekkit 2 Startup Program with Arguments
-- Usage: startup3 <1|3|4>
-- Arguments:
--   1 - Display shell only on left monitor
--   3 - Split 3 ways: clock_split, iPod, reactor
--   4 - Split 4 ways: clock_split, iPod, reactor, (4th is shell)

local args = { ... }
local mode = tonumber(args[1])

-- Redirect to left monitor
local monitor = peripheral.wrap("left")
if not monitor then
    error("Left monitor not found!")
end
term.redirect(monitor)

-- Validate argument
if not mode or (mode ~= 1 and mode ~= 3 and mode ~= 4) then
    print("Usage: startup3 <1|3|4>")
    print("  1 - Shell only")
    print("  3 - Split 3 ways")
    print("  4 - Split 4 ways")
    return
end

-- Set text scale to 1 for startup
monitor.setTextScale(1)

-- Clear the monitor
term.clear()
term.setCursorPos(1, 1)

if mode == 1 then
    -- Option 1: Plain shell with text scale 1
    monitor.setTextScale(1)
    shell.run("shell")

elseif mode == 3 then
    -- Option 3: Split 3 ways with programs
    -- Clean up terminal state before calling split
    term.clear()
    term.setCursorPos(1, 1)
    
    -- Drain any pending events
    while os.pullEventRaw(0) do end
    
    -- Small delay to stabilize system state
    sleep(0.1)
    
    -- Now set text scale and run split
    monitor.setTextScale(0.5)
    shell.run("split_arg", "3", "clock_split", "iPod", "reactor")
    
elseif mode == 4 then
    -- Option 4: Split 4 ways with programs
    -- Clean up terminal state before calling split
    term.clear()
    term.setCursorPos(1, 1)
    
    -- Drain any pending events
    while os.pullEventRaw(0) do end
    
    -- Small delay to stabilize system state
    sleep(0.1)
    
    -- Now set text scale and run split
    monitor.setTextScale(0.5)
    shell.run("split_arg", "4", "clock_split", "iPod", "reactor")
end
