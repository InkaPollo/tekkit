local chamber = peripheral.wrap("ic2:reactor chamber_1")

print("Extracting exact EnderPearl Cell data...")

for i = 1, chamber.size() do
    local item = chamber.getItemMeta(i)
    
    if item and item.displayName then
        -- Find the exact cell
        if string.find(string.lower(item.displayName), "enderpearl") then
            print("\n--- RAW CELL STATS ---")
            -- Print every single variable attached to this cell
            textutils.pagedPrint(textutils.serialize(item))
            return -- Stop the script immediately after finding it
        end
    end
end

print("Could not find the cell.")
